---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.jsx';
---

<Layout title="Chris Parcel">
  <main class="container">
    <!-- client:load hydrates this React component on page load so Motion can animate it -->
    <Hero client:load />

    <section id="about" style="padding-block: 6rem;">
      <h2 style="font-size: clamp(1.75rem, 4vw, 2.5rem); margin-top: 0;">About</h2>
      <p style="color: var(--muted); max-width: 40rem;">
        This is placeholder content. Static sections like this ship zero
        JavaScript — only interactive islands (like the hero) are hydrated.
        Add your real bio, projects, and links here.
      </p>
    </section>
  </main>
</Layout>
