---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Chris Parcel"
  description="Chris Parcel — staff engineer in Los Angeles. About, experience, side projects, and writing."
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Onest:wght@400;500;600&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <header class="hero">
    <div class="id">
      <span class="nm">Chris Parcel</span>
    </div>
    <div class="contact">
      <a href="mailto:hello@chrisparcel.com">Email ↗</a>
      <a href="https://github.com/chrispy22" target="_blank" rel="noopener">GitHub ↗</a>
      <a href="https://www.linkedin.com/in/chris-parcel-167bb57/" target="_blank" rel="noopener">LinkedIn ↗</a>
    </div>
  </header>

  <div class="stage">
    <div class="content">
      <div class="side">
        <div class="cmds" id="cmds"></div>
      </div>
      <div class="sections" id="sections"></div>
    </div>
  </div>
</Layout>

<style is:global>
  .stage {
    max-width: 1180px;
    width: 100%;
    margin: 0 auto;
    padding: 0 40px 20px;
    flex: 1 0 auto;
  }

  /* ── HEADER ── */
  .hero {
    max-width: 1180px;
    width: 100%;
    margin: 0 auto;
    padding: 56px 40px 30px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
    flex-wrap: wrap;
  }
  .hero .contact {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    align-items: baseline;
    gap: 18px;
  }
  .hero .contact a {
    font-family: var(--sans);
    font-size: 13.5px;
    letter-spacing: 0.005em;
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-color: var(--rule);
    text-underline-offset: 3px;
    transition: color 0.2s, text-decoration-color 0.2s;
  }
  .hero .contact a:hover {
    color: var(--slate);
    text-decoration-color: var(--slate);
  }
  .hero .id {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .hero .nm {
    font-family: var(--display);
    font-weight: 600;
    font-size: 34px;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  /* dates use the site typeface (tabular figures), not a clashing mono */
  .jrow .y,
  .subitem .sy,
  .asub {
    font-family: var(--sans) !important;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
    font-weight: 500;
  }

  /* ── CONTENT (decoupled) ── */
  .content {
    margin-top: 0;
    padding-top: 44px;
    border-top: 1px solid var(--rule);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: 26px 40px;
    align-items: start;
  }
  .side {
    position: sticky;
    top: 20px;
    align-self: start;
  }
  .cmds {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .cmd {
    font-size: 16.5px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--ink-soft);
    cursor: pointer;
    text-align: left;
    background: none;
    border: 0;
    border-radius: 8px;
    padding: 9px 10px;
    margin-left: -10px;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: color 0.2s, background 0.2s;
  }
  .cmd:hover {
    color: var(--ink);
    background: color-mix(in oklch, var(--bh) 10%, transparent);
  }
  .cmd .dot {
    display: none;
  }
  .cmd .ar {
    margin-left: auto;
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: 18px;
    line-height: 1;
    display: flex;
    align-items: center;
    opacity: 0;
    transition: transform 0.2s, opacity 0.2s;
  }
  .cmd .ar svg {
    display: block;
  }
  .cmd:hover .ar {
    opacity: 1;
    transform: translateX(3px);
  }
  .cmd.on {
    color: var(--ink);
    background: none;
    font-weight: 550;
  }
  .cmd.on .dot {
    opacity: 1;
  }
  .cmd.on .ar {
    opacity: 1;
    color: var(--bh);
  }
  .cmd.on .ar {
    transform: translateX(3px);
  }

  .sublist {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    transition: grid-template-rows 0.34s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .sublist.open {
    grid-template-rows: 1fr;
  }
  .sublist > div {
    min-height: 0;
  }
  .sub {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: 3px 0 8px 0;
  }
  .subitem {
    font-size: 13.5px;
    font-weight: 500;
    color: var(--ink-faint);
    text-align: left;
    cursor: pointer;
    background: none;
    border: 0;
    border-radius: 8px;
    padding: 8px 10px;
    margin-left: 9px;
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: center;
    transition: color 0.2s, background 0.2s;
  }
  .subitem:hover {
    color: var(--ink);
    background: color-mix(in oklch, var(--bh) 10%, transparent);
  }
  .subitem.on {
    color: var(--ink);
    font-weight: 650;
    background: none;
  }
  .subitem .st {
    line-height: 1.3;
  }
  .subitem .sy {
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--ink-faint);
    flex: none;
  }

  .article h2 {
    margin-bottom: 5px;
  }
  .asub {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.03em;
    color: var(--ink-faint);
    margin: 0 0 18px;
  }
  .article p {
    font-size: 15.5px;
    color: var(--ink-soft);
    line-height: 1.62;
    margin: 0 0 13px;
  }
  .article p:last-child {
    margin-bottom: 0;
  }
  .article em {
    font-style: italic;
    color: var(--ink);
  }

  .pbody h2,
  .secbody h2 {
    font-family: var(--sans);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0 0 8px;
  }
  .secbody .lede {
    font-size: 16.5px;
    color: var(--ink-soft);
    line-height: 1.6;
    margin: 0 0 14px;
  }
  .secbody .lede:last-child {
    margin-bottom: 0;
  }
  .jrow {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3px 18px;
    align-items: baseline;
    padding: 16px 0;
    border-top: 1px solid var(--rule);
  }
  .jrow:first-of-type {
    border-top: none;
    padding-top: 0;
  }
  .jrow .h {
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .jrow .h .r {
    color: var(--ink-soft);
    font-weight: 500;
  }
  .jrow .roles {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3px 18px;
    align-items: baseline;
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--ink-faint);
    margin-top: 1px;
  }
  .jrow .roles .y {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0;
    color: var(--ink-faint);
    white-space: nowrap;
  }
  .jrow .y {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0;
    color: var(--ink-faint);
    white-space: nowrap;
  }
  .jrow .d {
    grid-column: 1 / -1;
    font-size: 15px;
    color: var(--ink-soft);
    line-height: 1.5;
    margin-top: 2px;
  }

  /* ── stacked scroll sections ── */
  .sec {
    padding: 48px 0;
    border-top: 1px solid var(--rule);
  }
  .sec:first-child {
    padding-top: 0;
    border-top: none;
  }
  .wstack {
    display: flex;
    flex-direction: column;
  }
  .wart {
    padding: 40px 0;
    border-top: 1px solid var(--rule);
  }
  .wart:first-child {
    padding-top: 0;
    border-top: none;
  }
  .colophon {
    padding: 22px 0 8px;
    font-family: var(--sans);
    font-size: 12.5px;
    letter-spacing: 0.01em;
    color: var(--ink-faint);
    line-height: 1.6;
  }
  .colophon a {
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-color: var(--rule);
    text-underline-offset: 3px;
  }
  .colophon a:hover {
    color: var(--slate);
    text-decoration-color: var(--slate);
  }

  /* device-framed app preview (static screenshot) */
  .demos {
    display: flex;
    margin: 26px 0 4px;
  }
  .demo.ios {
    flex: 0 0 auto;
  }
  .demo-img {
    display: block;
    width: 500px;
    max-width: 100%;
    height: auto;
  }

  @media (max-width: 900px) {
    .content {
      grid-template-columns: 1fr;
      gap: 22px;
    }
    .side {
      position: static;
    }
    .hero,
    .stage {
      padding-left: 24px;
      padding-right: 24px;
    }
  }
</style>

<script>
  /* Content sections — rendered stacked; the left nav is a scroll-spy */
  const SECTIONS = [
    {
      key: 'about',
      hue: '#3E5575',
      label: 'About',
      noHead: true,
      panel: `<p class="lede">Hello, I'm Chris, an iOS Developer based in Los Angeles, who's been building apps since 2009. I built my first app in college, shortly after iOS opened its App Store, and have been going non-stop since then.</p>
        <p class="lede">In my early 20s, I both founded and worked at a number of small startups in New York City before finally landing at Block (Square) in 2018. I spent 8 glorious years at Square, working on both product and platform. I learned a ton, shipped a lot, and loved working with so many amazing people who cared deeply about their craft and Square's users. Then, rather suddenly, I was part of the more than 4,000 employees let go during the company-wide layoff in February 2026.</p>
        <p class="lede">Since then, I've been working on a personal project which, I'm happy to announce, will be launching soon, and has given me a chance to really explore the depths of integrating AI into both product and development stack.</p>
        <p class="lede">I'm now open for new opportunities. Shoot me an email if you'd like to connect.</p>`,
    },
    {
      key: 'work',
      hue: '#2F9E94',
      label: 'Experience',
      noHead: true,
      panel: `<div class="jrow"><div class="h">Staff Software Engineer <span class="r">· Block (Square)</span></div><div class="y">2021–2026</div>
          <div class="roles"><span>Senior Engineer</span><span class="y">2018–2021</span></div>
          <div class="d">Tech lead on the shared Cart Platform across every POS, and on a two-year Retail checkout overhaul — data models to UI, serving millions of daily users.</div></div>
        <div class="jrow"><div class="h">Senior iOS Developer <span class="r">· Verst</span></div><div class="y">2016–2017</div>
          <div class="d">Owned a mobile blogging tool from zero to launch and drove Swift adoption.</div></div>
        <div class="jrow"><div class="h">Co-Founder <span class="r">· Collectively Assembled</span></div><div class="y">2012–2013</div>
          <div class="d">Co-founded a fashion startup, raised $500k, shipped two apps in a year — one featured in the App Store.</div></div>
        <div class="jrow"><div class="h">B.A. Economics <span class="r">· UCLA</span></div><div class="y">2011</div>
          <div class="d">McKelvey entrepreneurship scholar. Built a flashcard app featured in the App Store, sold it after graduation.</div></div>`,
    },
    {
      key: 'central',
      hue: '#D49A28',
      label: 'Side projects',
      noHead: true,
      panel: `<h2 style="margin-bottom:6px">Central</h2>
        <div class="asub">Coming soon</div>
        <p class="lede">My one and only side project — a friendly home for your todos and pursuits: recipes to try, books to read, movies to watch, people to keep up with. Tech-forward, but warm. Designed and built end to end.</p>
        <p class="lede">It started as a place to park the things I kept losing track of — a book a friend mentioned, a restaurant worth remembering, a thought I wanted to come back to. Every capture tool I tried was either a rigid database or a blank void, so I built something in between: structured enough to be useful, loose enough that adding a thing never feels like a chore.</p>
        <p class="lede">Under the hood, AI quietly enriches and classifies each entry as it comes in, and a separate chat can reference and act on everything you've saved. The whole thing runs on the same agentic development system I use for my other work — Swift on the client, a small typed backend, and a deliberately boring data model I can trust. It's the project I use to keep my own craft sharp.</p>
        <div class="demos">
          <div class="demo ios"><img class="demo-img" src="/sponge-ios-poster.png" alt="Sponge — the Central iOS app" loading="lazy" width="1120" height="2220" /></div>
        </div>`,
    },
    {
      key: 'writing',
      hue: '#E0523B',
      label: 'My writing',
      noHead: true,
      articles: [
        {
          title: 'The loading state is the product',
          year: '2026',
          body: `<p>We treat loading states as the gap between the real screens — a spinner to apologize for the wait. But for anyone on a slow connection, the loading state <em>is</em> the product. It's the first thing they see and, on a bad day, the only thing.</p><p>The fix isn't a fancier spinner. It's designing the empty and pending states with the same care as the happy path: skeletons that match the real layout, optimistic writes that make a tap feel instant, and copy that tells the truth about what's happening.</p><p>Do it well and the wait disappears. Do it badly and no amount of polish downstream will save you.</p>`,
        },
        {
          title: 'Eight years on one payments platform',
          year: '2026',
          body: `<p>I spent eight years on essentially one system. That's unfashionable advice in an industry that rewards job-hopping, but staying taught me things you can only learn on a long timeline.</p><p>You watch your own decisions age. The clever abstraction that felt elegant in year two becomes the thing you curse in year five. You learn which shortcuts compound and which quietly disappear. Mostly you learn humility about what “done” means.</p><p>The platform work that mattered most was never glamorous. It was the boring reliability, the migration nobody noticed, the API that just kept working.</p><p>When I joined, the checkout path was a single monolithic method that had grown for years — a function so long that scrolling through it felt like reading a novel with no chapters. Nobody had written it maliciously. Every line had been added by a reasonable person solving a reasonable problem on a reasonable deadline. That's the thing about legacy code: it's just decisions, stacked.</p><p>The first year I mostly read. I traced money through the system until I could close my eyes and see it move. I learned where the bodies were buried — the tax edge cases, the currency rounding that had to happen in exactly one place, the retry logic that would double-charge a customer if you looked at it wrong. You cannot refactor what you do not understand, and understanding a payments system takes longer than anyone wants it to.</p><p>The second year I started to change things, carefully. The rule I gave myself was simple: never a rewrite, always a strangler. Wrap the old path, route a sliver of traffic through the new one, compare the outputs byte for byte, and only widen the pipe when the numbers matched for a week straight. It was slow. It was also the only approach that let me sleep.</p><p>By year four we had replaced the monolith without a single customer noticing. That is the strange, invisible reward of platform work: the highest compliment is silence. No incident channel, no angry merchant, no VP asking what happened to the numbers. Just money moving, quietly, the way it is supposed to.</p><p>Years five through eight were about leverage. Once the foundation was trustworthy, features that used to take a quarter took a week. New engineers could ship on their first day because the sharp edges were gone. I spent less time writing code and more time in documents and diagrams, trying to give twenty people the same mental model I had spent four years building. That translation — from what is in your head to what is in the team's head — turns out to be most of what senior engineering actually is.</p><p>What surprised me most was how much of the value compounded. A good abstraction does not just save you the afternoon you wrote it; it saves every afternoon after, for everyone. A flaky test you finally fix stops stealing an hour a week from the whole team, forever. Reliability is a savings account, and staying long enough to watch the interest accrue changed how I think about the work.</p><p>People ask if I regret not moving around more, chasing titles and comp. Honestly, no. There is a particular satisfaction in living with your own decisions long enough to be humbled by them, to fix them, and to watch the fixed version hold. You do not get that from a two-year stint. You get it from staying past the point where it is exciting, into the point where it is yours.</p><p>The platform outlasted my time on it, which was always the goal. The best thing you can build is something that no longer needs you — and the only way to know you have built it is to still be there when someone else ships on top of it without ever knowing your name.</p>`,
        },
        {
          title: "Designing Central's icon",
          year: '2026',
          body: `<p>Central needed an icon that felt warm and technical at once — a home for your thoughts that didn't look like a productivity tool shouting at you.</p><p>I went through dozens of directions before landing on a single letterform stroked in a soft rainbow gradient over a deep slate ground. The gradient nods to the range of things you keep in Central; the slate keeps it grounded and calm.</p><p>The lesson, again: subtraction. The final mark is the simplest one I drew.</p>`,
        },
        {
          title: 'Boring technology is a competitive advantage',
          year: '2025',
          body: `<p>Every team has a budget for novelty, and it's smaller than you think. Spend it on the one or two things that are genuinely core to what you're building, and be aggressively boring about everything else.</p><p>Boring technology has a property new technology can't offer: you already know how it fails. That knowledge is worth more than any feature list when it's 2am and production is down.</p><p>The goal was never to use the most interesting tools. It was to ship something people can rely on.</p>`,
        },
      ],
    },
  ];

  const reduce = matchMedia('(prefers-reduced-motion:reduce)').matches;
  const cmds = document.getElementById('cmds');
  const sections = document.getElementById('sections');

  function renderArticleHTML(s, i) {
    const a = s.articles[i];
    return `<div class="article"><h2>${a.title}</h2><div class="asub">${a.year}</div>${a.body}</div>`;
  }
  function goToArticle(key, i) {
    const el = document.getElementById('art-' + key + '-' + i);
    if (!el) return;
    const y = el.getBoundingClientRect().top + window.scrollY - 24;
    window.scrollTo({ top: Math.max(0, y), behavior: reduce ? 'auto' : 'smooth' });
  }

  /* left nav (+ writing sub-list) + stacked right-column sections */
  SECTIONS.forEach((s) => {
    const c = document.createElement('button');
    c.className = 'cmd';
    c.dataset.key = s.key;
    c.style.setProperty('--bh', s.hue);
    const arw = s.articles
      ? '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>'
      : '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>';
    c.innerHTML = `<span class="dot"></span>${s.label}<span class="ar">${arw}</span>`;
    c.addEventListener('click', () => goTo(s.key));
    cmds.appendChild(c);

    if (s.articles) {
      const wrap = document.createElement('div');
      wrap.className = 'sublist';
      wrap.dataset.key = s.key;
      wrap.style.setProperty('--bh', s.hue);
      const inner = document.createElement('div');
      const sub = document.createElement('div');
      sub.className = 'sub';
      s.articles.forEach((a, i) => {
        const b = document.createElement('button');
        b.className = 'subitem';
        b.dataset.idx = i;
        b.innerHTML = `<span class="st">${a.title}</span><span class="sy">${a.year}</span>`;
        b.addEventListener('click', () => goToArticle(s.key, i));
        sub.appendChild(b);
      });
      inner.appendChild(sub);
      wrap.appendChild(inner);
      cmds.appendChild(wrap);
    }

    const sec = document.createElement('section');
    sec.className = 'sec';
    sec.id = 'sec-' + s.key;
    sec.dataset.key = s.key;
    sec.style.setProperty('--bh', s.hue);
    if (s.articles) {
      sec.innerHTML =
        `<div class="secbody"><div class="wstack">` +
        s.articles
          .map((a, i) => `<div class="wart" id="art-${s.key}-${i}">${renderArticleHTML(s, i)}</div>`)
          .join('') +
        `</div></div>`;
    } else {
      sec.innerHTML = `<div class="secbody">${s.panel}</div>`;
    }
    sections.appendChild(sec);
  });

  /* tail spacer: guarantee the page can scroll far enough that even a short
     last section's top reaches the scroll-spy activation line */
  const tail = document.createElement('div');
  tail.className = 'tailspace';
  sections.appendChild(tail);
  const colo = document.createElement('div');
  colo.className = 'colophon';
  colo.innerHTML = `Designed &amp; coded with Claude. Inspiration from Brittany Chiang's <a href="https://brittanychiang.com/" target="_blank" rel="noopener">site</a>.`;
  sections.appendChild(colo);
  function updateSpacer() {
    tail.style.height = '0px';
    const arts = sections.querySelectorAll('.wart');
    const secs = sections.querySelectorAll('.sec');
    const last = arts.length ? arts[arts.length - 1] : secs[secs.length - 1];
    if (!last) return;
    const coloH = colo.getBoundingClientRect().height;
    const need = window.innerHeight - 240 - last.getBoundingClientRect().height + 24 - coloH;
    tail.style.height = Math.max(0, need) + 'px';
  }
  updateSpacer();

  /* click a nav item -> smooth-scroll to its section */
  function goTo(key) {
    const el = document.getElementById('sec-' + key);
    if (!el) return;
    const y = el.getBoundingClientRect().top + window.scrollY - 24;
    window.scrollTo({ top: Math.max(0, y), behavior: reduce ? 'auto' : 'smooth' });
  }

  /* scroll-spy: highlight the section currently in view */
  const cmdEls = [...cmds.querySelectorAll('.cmd')];
  const secEls = SECTIONS.map((s) => document.getElementById('sec-' + s.key));
  let spyRaf = 0;
  function spy() {
    spyRaf = 0;
    let active = SECTIONS[0].key;
    for (const el of secEls) {
      if (el.getBoundingClientRect().top <= 240) active = el.dataset.key;
      else break;
    }
    if (
      window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 4 &&
      secEls[secEls.length - 1].getBoundingClientRect().top <= 240
    )
      active = SECTIONS[SECTIONS.length - 1].key;
    cmdEls.forEach((c) => c.classList.toggle('on', c.dataset.key === active));
    cmds.querySelectorAll('.sublist').forEach((w) => w.classList.toggle('open', w.dataset.key === active));
    const atBottom = window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 4;
    SECTIONS.forEach((s) => {
      if (!s.articles) return;
      const wrap = cmds.querySelector(`.sublist[data-key="${s.key}"]`);
      if (!wrap) return;
      const arts = [...document.querySelectorAll(`#sec-${s.key} .wart`)];
      let ai = 0;
      arts.forEach((el, idx) => {
        if (el.getBoundingClientRect().top <= 240) ai = idx;
      });
      if (atBottom) ai = arts.length - 1;
      [...wrap.querySelectorAll('.subitem')].forEach((b) => b.classList.toggle('on', +b.dataset.idx === ai));
    });
  }
  addEventListener('scroll', () => {
    if (!spyRaf) spyRaf = requestAnimationFrame(spy);
  }, { passive: true });
  addEventListener('resize', () => {
    updateSpacer();
    if (!spyRaf) spyRaf = requestAnimationFrame(spy);
