---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Chris Parcel"
  description="Chris Parcel — software developer in Los Angeles. Experience, side projects, writing, and how to get in touch."
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="top">
    <span class="nm">Chris Parcel</span>
    <span class="meta">Software developer · Los Angeles · Open to work</span>
  </div>

  <div class="stage">
    <!-- CONTENT -->
    <div class="content">
      <div class="side">
        <div class="cmds" id="cmds"></div>
      </div>
      <div class="work-area">
        <div class="panel" id="panel"></div>
      </div>
    </div>
  </div>

  <!-- FOOTER: Chris answering a queue of agents -->
  <footer class="footer">
    <div class="qscene">
      <div class="cast">
        <div class="bubble" id="bubble"></div>
        <div class="chris" id="chris">
          <div class="shadow"></div>
          <div class="head">
            <div class="brow l"></div>
            <div class="brow r"></div>
            <div class="eye l"></div>
            <div class="eye r"></div>
            <div class="nose"></div>
            <div class="stubble"></div>
            <div class="mouth"></div>
          </div>
          <div class="hair"></div>
          <div class="body">
            <div class="collar"></div>
            <div class="arm l"></div>
            <div class="arm r"></div>
          </div>
        </div>
      </div>
      <div class="queue" id="queue"></div>
    </div>
  </footer>
</Layout>

<style is:global>
  .stage {
    max-width: 1180px;
    width: 100%;
    margin: 0 auto;
    padding: 0 40px 20px;
    flex: 1 0 auto;
  }

  .top {
    max-width: 1180px;
    width: 100%;
    margin: 0 auto;
    padding: 24px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .top .nm {
    font-weight: 700;
    font-size: 26px;
    letter-spacing: -0.02em;
  }
  .top .meta {
    font-family: var(--sans);
    font-weight: 500;
    font-size: 14px;
    letter-spacing: 0.005em;
    color: var(--ink-soft);
  }

  .scenebar,
  .scenetoggle {
    display: none;
  }

  /* ── FOOTER: Chris answering a queue of agents ── */
  .footer {
    flex: none;
    max-width: 1180px;
    width: 100%;
    margin: 0 auto;
    padding: 8px 40px 24px;
  }
  .qscene {
    position: relative;
    display: flex;
    align-items: flex-end;
    gap: 20px;
    min-height: 190px;
    padding-top: 30px;
  }
  .queue {
    position: relative;
    flex: 1;
    height: 150px;
    align-self: flex-end;
  }
  .agent {
    position: absolute;
    bottom: 0;
    width: 56px;
    transition: left 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s, transform 0.5s;
  }
  .agent.enter {
    opacity: 0;
    transform: translateX(26px);
  }
  .agent.leave {
    opacity: 0;
    transform: translateY(-16px);
  }
  .agent .arig {
    position: relative;
  }
  .agent .ant {
    position: absolute;
    left: 50%;
    top: -13px;
    width: 2px;
    height: 13px;
    background: var(--ink-faint);
    transform: translateX(-50%);
  }
  .agent .ant::after {
    content: '';
    position: absolute;
    left: 50%;
    top: -5px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    transform: translateX(-50%);
    background: var(--ah);
    opacity: 0.5;
    transition: opacity 0.3s, box-shadow 0.3s;
  }
  .agent.active .ant::after {
    opacity: 1;
    box-shadow: 0 0 8px 1px var(--ah);
  }
  .agent .abody {
    position: relative;
    width: 52px;
    height: 44px;
    margin: 0 auto;
    border-radius: 14px;
    background: var(--ah);
    box-shadow: inset -5px -5px 0 rgba(0, 0, 0, 0.09), 0 10px 20px -12px rgba(35, 33, 29, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    filter: saturate(0.85) opacity(0.9);
    transition: filter 0.35s;
  }
  .agent.active .abody {
    filter: saturate(1) opacity(1);
  }
  .agent.asking {
    transform: translateY(-7px);
  }
  .agent .aeye {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #20201d;
  }
  .agent .glow {
    position: absolute;
    left: 50%;
    bottom: -8px;
    width: 38px;
    height: 9px;
    transform: translateX(-50%);
    background: radial-gradient(
      50% 50% at 50% 50%,
      color-mix(in oklch, var(--ah) 45%, transparent),
      transparent 70%
    );
    filter: blur(1px);
    opacity: 0.4;
  }
  /* the front agent's question, pointing down toward Chris */
  .agent .qbub {
    position: absolute;
    bottom: 100%;
    left: 50%;
    width: 162px;
    transform: translate(-50%, -16px) scale(0.96);
    transform-origin: 50% 100%;
    background: #fff;
    border: 1.5px solid var(--ah);
    border-radius: 13px;
    padding: 9px 12px;
    font-size: 12.5px;
    line-height: 1.38;
    color: var(--ink);
    text-align: center;
    box-shadow: 0 2px 4px rgba(35, 33, 29, 0.04), 0 16px 30px -20px rgba(35, 33, 29, 0.5);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s, transform 0.3s;
    z-index: 6;
  }
  .agent .qbub::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 100%;
    transform: translateX(-50%);
    border: 8px solid transparent;
    border-top-color: var(--ah);
  }
  .agent .qbub::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 100%;
    margin-top: -1.6px;
    transform: translateX(-50%);
    border: 7px solid transparent;
    border-top-color: #fff;
    z-index: 1;
  }
  .agent.asking .qbub {
    opacity: 1;
    transform: translate(-50%, -24px) scale(1);
  }

  /* thinking dots while queued; hidden once it's asking */
  .agent .think {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translate(-50%, -8px);
    display: flex;
    gap: 3.5px;
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: 999px;
    padding: 5px 8px;
    box-shadow: 0 8px 18px -13px rgba(35, 33, 29, 0.6);
    transition: opacity 0.3s;
    z-index: 5;
  }
  .agent .think i {
    width: 3.5px;
    height: 3.5px;
    border-radius: 50%;
    background: var(--ink-faint);
    animation: tdot 1.5s ease-in-out infinite;
  }
  .agent .think i:nth-child(2) {
    animation-delay: 0.22s;
  }
  .agent .think i:nth-child(3) {
    animation-delay: 0.44s;
  }
  @keyframes tdot {
    0%,
    65%,
    100% {
      opacity: 0.25;
      transform: translateY(0);
    }
    30% {
      opacity: 1;
      transform: translateY(-3px);
    }
  }
  .agent.asking .think,
  .agent.leave .think {
    opacity: 0;
  }

  @media (max-width: 900px) {
    .footer {
      padding-left: 24px;
      padding-right: 24px;
    }
    .qscene {
      gap: 12px;
    }
  }

  /* Chris */
  .cast {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    z-index: 2;
  }
  .bubble {
    position: relative;
    max-width: 196px;
    margin: 0 0 30px 20px;
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: 16px;
    padding: 13px 16px;
    box-shadow: 0 1px 2px rgba(35, 33, 29, 0.04), 0 16px 34px -22px rgba(35, 33, 29, 0.3);
    font-size: 15.5px;
    line-height: 1.45;
    color: var(--ink);
    text-align: center;
    opacity: 0;
    transform: translateY(8px) scale(0.98);
    transition: opacity 0.3s, transform 0.3s;
  }
  .bubble.show {
    opacity: 1;
    transform: none;
  }
  .bubble::after {
    content: '';
    position: absolute;
    left: 55px;
    bottom: -9px;
    width: 16px;
    height: 16px;
    transform: translateX(-50%) rotate(45deg);
    background: #fff;
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .bubble b {
    font-weight: 700;
  }

  .chris {
    position: relative;
    width: 150px;
    flex: none;
    transform-origin: 50% 100%;
  }
  .chris.talk {
    animation: sway 1.4s ease-in-out;
  }
  @keyframes sway {
    0%,
    100% {
      transform: rotate(0);
    }
    25% {
      transform: rotate(-1.4deg);
    }
    60% {
      transform: rotate(1deg);
    }
  }
  .chris .shadow {
    position: absolute;
    left: 50%;
    bottom: -6px;
    width: 120px;
    height: 16px;
    transform: translateX(-50%);
    background: radial-gradient(50% 50% at 50% 50%, rgba(35, 33, 29, 0.18), transparent 70%);
  }
  .head {
    position: relative;
    width: 88px;
    height: 90px;
    border-radius: 46% 46% 48% 48% / 44% 44% 52% 52%;
    background: var(--skin);
    margin: 0 auto -10px;
    box-shadow: inset -6px -7px 0 rgba(0, 0, 0, 0.05);
    z-index: 2;
  }
  .hair {
    position: absolute;
    left: 50%;
    top: -13px;
    width: 104px;
    height: 48px;
    transform: translateX(-51%);
    background: linear-gradient(150deg, var(--hair) 58%, var(--hair-2));
    z-index: 3;
    border-radius: 54% 56% 42% 44% / 80% 78% 32% 32%;
  }
  .hair::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 20px;
    width: 26px;
    height: 22px;
    background: linear-gradient(150deg, var(--hair), var(--hair-2));
    border-radius: 60% 40% 50% 50% / 70% 60% 40% 40%;
    transform: rotate(-12deg);
  }
  .hair::after {
    content: '';
    position: absolute;
    right: 5px;
    top: 24px;
    width: 22px;
    height: 26px;
    background: linear-gradient(150deg, var(--hair), var(--hair-2));
    border-radius: 50% 60% 45% 55% / 55% 65% 40% 45%;
    transform: rotate(10deg);
  }
  .brow {
    position: absolute;
    top: 36px;
    width: 15px;
    height: 4px;
    border-radius: 3px;
    background: var(--hair-2);
    z-index: 4;
  }
  .brow.l {
    left: 22px;
    transform: rotate(-4deg);
  }
  .brow.r {
    right: 22px;
    transform: rotate(4deg);
  }
  .eye {
    position: absolute;
    top: 44px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #3a2c22;
    z-index: 4;
    transition: transform 0.08s;
  }
  .eye.l {
    left: 26px;
  }
  .eye.r {
    right: 26px;
  }
  .chris.blink .eye {
    transform: scaleY(0.12);
  }
  .nose {
    position: absolute;
    top: 50px;
    left: 50%;
    transform: translateX(-50%);
    width: 6px;
    height: 12px;
    border-radius: 0 0 4px 4px;
    background: var(--skin-sh);
    opacity: 0.55;
    z-index: 4;
  }
  .stubble {
    position: absolute;
    left: 50%;
    top: 52px;
    transform: translateX(-50%);
    width: 70px;
    height: 34px;
    z-index: 3;
    border-radius: 0 0 46% 46% / 0 0 80% 80%;
    background: radial-gradient(120% 90% at 50% 100%, var(--stubble) 0 55%, transparent 72%);
    opacity: 0.5;
    -webkit-mask: radial-gradient(120% 90% at 50% 100%, #000 0 62%, transparent 74%);
  }
  .glasses {
    position: absolute;
    top: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: none;
  }
  .lens {
    display: none;
  }
  .bridge {
    display: none;
  }
  .mouth {
    position: absolute;
    top: 72px;
    left: 50%;
    transform: translateX(-50%);
    width: 18px;
    height: 3px;
    border-radius: 3px;
    background: #9a5f43;
    z-index: 4;
    transition: height 0.1s, border-radius 0.1s;
  }
  .chris.talk .mouth {
    animation: talk 0.28s steps(1) infinite;
  }
  @keyframes talk {
    0% {
      height: 3px;
      border-radius: 3px;
    }
    50% {
      height: 11px;
      width: 16px;
      border-radius: 0 0 10px 10px;
    }
  }
  .body {
    position: relative;
    width: 104px;
    height: 82px;
    margin: 0 auto;
    background: var(--shirt);
    border-radius: 30px 30px 16px 16px;
    z-index: 1;
    box-shadow: inset -8px -8px 0 rgba(0, 0, 0, 0.05), inset 0 2px 0 rgba(255, 255, 255, 0.5);
  }
  .collar {
    position: absolute;
    top: -2px;
    left: 50%;
    transform: translateX(-50%);
    width: 30px;
    height: 15px;
    background: var(--skin);
    border-radius: 0 0 40px 40px;
    box-shadow: 0 2px 0 var(--skin-sh);
  }
  .arm {
    position: absolute;
    top: 14px;
    width: 20px;
    height: 58px;
    background: var(--shirt);
    border-radius: 12px;
    z-index: 0;
    transform-origin: top center;
    box-shadow: inset -3px 0 0 rgba(0, 0, 0, 0.05);
  }
  .arm.l {
    left: -6px;
    transform: rotate(9deg);
  }
  .arm.r {
    right: -6px;
    transform: rotate(-9deg);
  }
  .chris.talk .arm.r {
    animation: point 1.4s ease-in-out;
  }
  @keyframes point {
    0%,
    100% {
      transform: rotate(-9deg);
    }
    40% {
      transform: rotate(-42deg);
    }
    70% {
      transform: rotate(-30deg);
    }
  }

  /* ── CONTENT (decoupled) ── */
  .content {
    margin-top: 0;
    padding-top: 30px;
    border-top: 1px solid var(--rule);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: 26px 40px;
    align-items: start;
  }
  .side {
    position: sticky;
    top: 20px;
    align-self: start;
  }
  .side .kicker {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 14px;
  }
  .cmds {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .cmd {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink-soft);
    cursor: pointer;
    text-align: left;
    background: none;
    border: 0;
    border-radius: 8px;
    padding: 9px 10px;
    margin-left: -10px;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: color 0.2s, background 0.2s;
  }
  .cmd:hover {
    color: var(--ink);
    background: color-mix(in oklch, var(--bh) 10%, transparent);
  }
  .cmd .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--bh);
    flex: none;
    opacity: 0.55;
    transition: opacity 0.2s;
  }
  .cmd:hover .dot {
    opacity: 1;
  }
  .cmd .ar {
    margin-left: auto;
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: 13px;
    opacity: 0;
    transition: transform 0.2s, opacity 0.2s;
  }
  .cmd:hover .ar {
    opacity: 1;
    transform: translateX(3px);
  }
  .cmd.on {
    color: var(--ink);
    background: none;
  }
  .cmd.on .dot {
    opacity: 1;
  }
  .cmd.on .ar {
    opacity: 1;
    color: var(--bh);
  }
  .cmd.on .ar {
    transform: none;
  }
  .cmd[data-key='writing'].on .ar {
    transform: rotate(180deg);
  }

  .sublist {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    transition: grid-template-rows 0.34s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .sublist.open {
    grid-template-rows: 1fr;
  }
  .sublist > div {
    min-height: 0;
  }
  .sub {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: 3px 0 8px 0;
  }
  .subitem {
    font-size: 13.5px;
    font-weight: 500;
    color: var(--ink-faint);
    text-align: left;
    cursor: pointer;
    background: none;
    border: 0;
    border-radius: 8px;
    padding: 8px 10px 8px 29px;
    margin-left: -10px;
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: baseline;
    transition: color 0.2s, background 0.2s;
  }
  .subitem:hover {
    color: var(--ink);
    background: color-mix(in oklch, var(--bh) 10%, transparent);
  }
  .subitem.on {
    color: var(--ink);
    background: color-mix(in oklch, var(--bh) 8%, transparent);
  }
  .subitem .st {
    line-height: 1.3;
  }
  .subitem .sy {
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--ink-faint);
    flex: none;
  }

  .article h2 {
    margin-bottom: 5px;
  }
  .article .asub {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.03em;
    color: var(--ink-faint);
    margin: 0 0 18px;
  }
  .article p {
    font-size: 15.5px;
    color: var(--ink-soft);
    line-height: 1.62;
    margin: 0 0 13px;
  }
  .article p:last-child {
    margin-bottom: 0;
  }
  .article em {
    font-style: italic;
    color: var(--ink);
  }

  .panel {
    width: 100%;
    background: none;
    border: 0;
    border-radius: 0;
  }
  .panel.exit {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.22s, transform 0.22s;
  }
  .phead {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 0 14px;
    margin-bottom: 6px;
    border-bottom: 1px solid var(--rule);
    font-family: var(--mono);
    font-size: 11.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .phead .pd {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--bh);
  }
  .pbody {
    padding: 9px 0 0;
  }
  .pbody > * {
    opacity: 0;
    animation: rise 0.45s ease forwards;
  }
  .pbody > *:nth-child(1) {
    animation-delay: 0.05s;
  }
  .pbody > *:nth-child(2) {
    animation-delay: 0.13s;
  }
  .pbody > *:nth-child(3) {
    animation-delay: 0.21s;
  }
  .pbody > *:nth-child(4) {
    animation-delay: 0.29s;
  }
  .pbody > *:nth-child(5) {
    animation-delay: 0.37s;
  }
  @keyframes rise {
    to {
      opacity: 1;
    }
  }

  .pbody h2 {
    font-size: 23px;
    font-weight: 800;
    letter-spacing: -0.025em;
    margin: 0 0 6px;
  }
  .pbody .lede {
    font-size: 16px;
    color: var(--ink-soft);
    line-height: 1.55;
    margin: 0 0 4px;
  }
  .jrow {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3px 18px;
    align-items: baseline;
    padding: 16px 0;
    border-top: 1px solid var(--rule);
  }
  .jrow:first-of-type {
    border-top: none;
    padding-top: 0;
  }
  .jrow .h {
    font-size: 17px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .jrow .h .r {
    color: var(--ink-soft);
    font-weight: 500;
  }
  .jrow .y {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink-faint);
    white-space: nowrap;
  }
  .jrow .d {
    grid-column: 1 / -1;
    font-size: 15px;
    color: var(--ink-soft);
    line-height: 1.5;
    margin-top: 2px;
  }
  .plist a {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: baseline;
    padding: 12px 0;
    border-top: 1px solid var(--rule);
    color: var(--ink);
  }
  .plist a:first-child {
    border-top: none;
  }
  .plist a:hover {
    color: #2e405c;
  }
  .plist a .t {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .plist a .y {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink-faint);
  }
  .central {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  .central .ic {
    width: 52px;
    height: 52px;
    border-radius: 13px;
    overflow: hidden;
    flex: none;
    box-shadow: 0 3px 10px -3px rgba(0, 0, 0, 0.5);
  }
  .central .go {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-top: 14px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.03em;
    border: 1px solid var(--slate);
    color: var(--slate);
    border-radius: 999px;
    padding: 8px 14px;
    transition: background 0.2s, color 0.2s;
  }
  .central .go:hover {
    background: var(--slate);
    color: #fff;
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 22px;
    margin-top: 20px;
  }
  .links a {
    font-family: var(--mono);
    font-size: 13.5px;
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--rule);
    text-underline-offset: 4px;
    transition: color 0.2s, text-decoration-color 0.2s;
  }
  .links a:hover {
    color: var(--slate);
    text-decoration-color: var(--slate);
  }
  .contact-lede {
    font-size: 16px;
    color: var(--ink-soft);
    margin: 0 0 16px;
    line-height: 1.55;
  }

  @media (max-width: 900px) {
    .content {
      grid-template-columns: 1fr;
      gap: 22px;
    }
    .side {
      position: static;
    }
    .top,
    .stage {
      padding-left: 24px;
      padding-right: 24px;
    }
  }
</style>

<script>
  const CENTRAL_ICO = (() => {
    const RB = ['#2F9E94', '#D49A28', '#E0523B', '#6E5AA8'];
    const stops = RB.map(
      (c, i) => `<stop offset="${((i / 3) * 100).toFixed(0)}%" stop-color="${c}"/>`
    ).join('');
    return `<svg viewBox="0 0 100 100" width="100%" height="100%" style="display:block" fill="none">
      <defs><linearGradient id="cbg" x1="0.1" y1="0" x2="0.9" y2="1"><stop offset="0" stop-color="#5A6B85"/><stop offset="1" stop-color="#262E3D"/></linearGradient>
      <linearGradient id="crb" x1="0" y1="0.1" x2="1" y2="0.9">${stops}</linearGradient></defs>
      <rect width="100" height="100" fill="url(#cbg)"/>
      <text x="50" y="53" text-anchor="middle" dominant-baseline="central" font-family="'Figtree',sans-serif" font-weight="700" font-size="76" fill="none" stroke="url(#crb)" stroke-width="6.5" paint-order="stroke" stroke-linejoin="round" stroke-linecap="round">C</text></svg>`;
  })();

  /* Content sections — driven by the pills */
  const SECTIONS = [
    {
      key: 'about',
      hue: '#3E5575',
      label: 'About',
      noHead: true,
      panel: `<p class="lede" style="margin-bottom:14px">Software engineer with 15 years of experience across product and platform. An expert in iOS development, and formerly a founder. Now focused on integrating AI into user-facing features and the development stack.</p>
        <p class="lede">In between, I spent a couple of years as a freelance iOS consultant — taking on client work while pursuing side projects and traveling around the world.</p>`,
    },
    {
      key: 'work',
      hue: '#2F9E94',
      label: 'Experience',
      noHead: true,
      panel: `<div class="jrow"><div class="h">Staff Software Engineer <span class="r">· Block (Square)</span></div><div class="y">2018–2026</div>
          <div class="d">Tech lead on the shared Cart Platform across every POS, and on a two-year Retail checkout overhaul — data models to UI, serving millions of daily users.</div></div>
        <div class="jrow"><div class="h">Senior iOS Developer <span class="r">· Verst</span></div><div class="y">2016–2017</div>
          <div class="d">Owned a mobile blogging tool from zero to launch and drove Swift adoption.</div></div>
        <div class="jrow"><div class="h">Co-Founder <span class="r">· Collectively Assembled</span></div><div class="y">2012–2013</div>
          <div class="d">Co-founded a fashion startup, raised $500k, shipped two apps in a year — one featured in the App Store.</div></div>
        <div class="jrow"><div class="h">B.A. Economics <span class="r">· UCLA</span></div><div class="y">2011</div>
          <div class="d">McKelvey entrepreneurship scholar. Built a flashcard app featured in the App Store, sold it after graduation.</div></div>`,
    },
    {
      key: 'central',
      hue: '#D49A28',
      label: 'Side projects',
      noHead: true,
      panel: `<h2 style="margin-bottom:2px">Central</h2>
        <p class="lede">My one and only side project — a friendly home for your todos and pursuits: recipes to try, books to read, movies to watch, people to keep up with. Tech-forward, but warm. Designed and built end to end.</p>
        <a class="go" href="#" target="_blank" rel="noopener">Visit central.app ↗</a>`,
    },
    {
      key: 'writing',
      hue: '#E0523B',
      label: 'My writing',
      noHead: true,
      articles: [
        {
          title: 'The loading state is the product',
          year: '2026',
          body: `<p>We treat loading states as the gap between the real screens — a spinner to apologize for the wait. But for anyone on a slow connection, the loading state <em>is</em> the product. It's the first thing they see and, on a bad day, the only thing.</p><p>The fix isn't a fancier spinner. It's designing the empty and pending states with the same care as the happy path: skeletons that match the real layout, optimistic writes that make a tap feel instant, and copy that tells the truth about what's happening.</p><p>Do it well and the wait disappears. Do it badly and no amount of polish downstream will save you.</p>`,
        },
        {
          title: 'Eight years on one payments platform',
          year: '2026',
          body: `<p>I spent eight years on essentially one system. That's unfashionable advice in an industry that rewards job-hopping, but staying taught me things you can only learn on a long timeline.</p><p>You watch your own decisions age. The clever abstraction that felt elegant in year two becomes the thing you curse in year five. You learn which shortcuts compound and which quietly disappear. Mostly you learn humility about what “done” means.</p><p>The platform work that mattered most was never glamorous. It was the boring reliability, the migration nobody noticed, the API that just kept working.</p><p>When I joined, the checkout path was a single monolithic method that had grown for years — a function so long that scrolling through it felt like reading a novel with no chapters. Nobody had written it maliciously. Every line had been added by a reasonable person solving a reasonable problem on a reasonable deadline. That's the thing about legacy code: it's just decisions, stacked.</p><p>The first year I mostly read. I traced money through the system until I could close my eyes and see it move. I learned where the bodies were buried — the tax edge cases, the currency rounding that had to happen in exactly one place, the retry logic that would double-charge a customer if you looked at it wrong. You cannot refactor what you do not understand, and understanding a payments system takes longer than anyone wants it to.</p><p>The second year I started to change things, carefully. The rule I gave myself was simple: never a rewrite, always a strangler. Wrap the old path, route a sliver of traffic through the new one, compare the outputs byte for byte, and only widen the pipe when the numbers matched for a week straight. It was slow. It was also the only approach that let me sleep.</p><p>By year four we had replaced the monolith without a single customer noticing. That is the strange, invisible reward of platform work: the highest compliment is silence. No incident channel, no angry merchant, no VP asking what happened to the numbers. Just money moving, quietly, the way it is supposed to.</p><p>Years five through eight were about leverage. Once the foundation was trustworthy, features that used to take a quarter took a week. New engineers could ship on their first day because the sharp edges were gone. I spent less time writing code and more time in documents and diagrams, trying to give twenty people the same mental model I had spent four years building. That translation — from what is in your head to what is in the team's head — turns out to be most of what senior engineering actually is.</p><p>What surprised me most was how much of the value compounded. A good abstraction does not just save you the afternoon you wrote it; it saves every afternoon after, for everyone. A flaky test you finally fix stops stealing an hour a week from the whole team, forever. Reliability is a savings account, and staying long enough to watch the interest accrue changed how I think about the work.</p><p>People ask if I regret not moving around more, chasing titles and comp. Honestly, no. There is a particular satisfaction in living with your own decisions long enough to be humbled by them, to fix them, and to watch the fixed version hold. You do not get that from a two-year stint. You get it from staying past the point where it is exciting, into the point where it is yours.</p><p>The platform outlasted my time on it, which was always the goal. The best thing you can build is something that no longer needs you — and the only way to know you have built it is to still be there when someone else ships on top of it without ever knowing your name.</p>`,
        },
        {
          title: "Designing Central's icon",
          year: '2026',
          body: `<p>Central needed an icon that felt warm and technical at once — a home for your thoughts that didn't look like a productivity tool shouting at you.</p><p>I went through dozens of directions before landing on a single letterform stroked in a soft rainbow gradient over a deep slate ground. The gradient nods to the range of things you keep in Central; the slate keeps it grounded and calm.</p><p>The lesson, again: subtraction. The final mark is the simplest one I drew.</p>`,
        },
        {
          title: 'Boring technology is a competitive advantage',
          year: '2025',
          body: `<p>Every team has a budget for novelty, and it's smaller than you think. Spend it on the one or two things that are genuinely core to what you're building, and be aggressively boring about everything else.</p><p>Boring technology has a property new technology can't offer: you already know how it fails. That knowledge is worth more than any feature list when it's 2am and production is down.</p><p>The goal was never to use the most interesting tools. It was to ship something people can rely on.</p>`,
        },
      ],
    },
    {
      key: 'contact',
      hue: '#6E5AA8',
      label: 'Get in touch',
      noHead: true,
      panel: `<h2>Say hello</h2>
        <div class="links">
          <a href="mailto:hello@chrisparcel.com">hello@chrisparcel.com</a>
          <a href="#" target="_blank" rel="noopener">GitHub ↗</a>
          <a href="#" target="_blank" rel="noopener">LinkedIn ↗</a>
        </div>`,
    },
  ];

  /* Technical Q&A — a bot asks, Chris answers */
  const QA = [
    { q: 'Optimistic sync or last-write-wins?', a: 'Optimistic, with a clear undo.' },
    { q: 'Diff the schema before migrating?', a: 'Always. Migrations are one-way doors.' },
    { q: 'Is this coroutine leaking?', a: 'Scope it to the lifecycle and watch.' },
    { q: 'Retry with backoff, or fail fast?', a: 'Backoff — then surface it honestly.' },
    { q: 'Memoize this selector?', a: 'Only if the profiler asks you to.' },
    { q: 'Wrap these writes in a transaction?', a: 'Yes. Half-written state is a bug.' },
    { q: 'How long should I debounce writes?', a: '300ms. Feels instant, saves the disk.' },
    { q: 'Cache invalidation — TTL or events?', a: 'Events. TTLs lie eventually.' },
    { q: 'How should the offline queue behave?', a: 'Idempotent, ordered, forgiving.' },
    { q: 'Main-thread work sneaking in here?', a: 'Move it off. Never block a tap.' },
    { q: 'Should this API be paginated?', a: 'If it can grow unbounded, yes.' },
    { q: 'Force-unwrap or guard let?', a: 'Guard. Crash on purpose, not by accident.' },
  ];

  const reduce = matchMedia('(prefers-reduced-motion:reduce)').matches;
  const chris = document.getElementById('chris');
  const bubble = document.getElementById('bubble');
  const cmds = document.getElementById('cmds');
  const panel = document.getElementById('panel');
  const queueEl = document.getElementById('queue');
  const HUES = ['#2F9E94', '#D49A28', '#E0523B', '#6E5AA8', '#3178C6', '#3E5575'];

  /* build command pills */
  let current = null,
    curArticle = {};
  SECTIONS.forEach((s) => {
    const c = document.createElement('button');
    c.className = 'cmd';
    c.dataset.key = s.key;
    c.style.setProperty('--bh', s.hue);
    c.innerHTML = `<span class="dot"></span>${s.label}<span class="ar">${s.articles ? '▾' : '→'}</span>`;
    c.addEventListener('click', () => dispatch(s.key));
    cmds.appendChild(c);
    if (s.articles) {
      const wrap = document.createElement('div');
      wrap.className = 'sublist';
      wrap.dataset.key = s.key;
      wrap.style.setProperty('--bh', s.hue);
      const inner = document.createElement('div');
      const sub = document.createElement('div');
      sub.className = 'sub';
      s.articles.forEach((a, i) => {
        const b = document.createElement('button');
        b.className = 'subitem';
        b.dataset.idx = i;
        b.innerHTML = `<span class="st">${a.title}</span><span class="sy">${a.year}</span>`;
        b.addEventListener('click', (e) => {
          e.stopPropagation();
          loadArticle(s.key, i);
        });
        sub.appendChild(b);
      });
      inner.appendChild(sub);
      wrap.appendChild(inner);
      cmds.appendChild(wrap);
    }
  });

  function renderArticleHTML(s, i) {
    const a = s.articles[i];
    return `<div class="article"><h2>${a.title}</h2><div class="asub">${a.year}</div>${a.body}</div>`;
  }
  const sideEl = document.querySelector('.side');
  const workArea = document.querySelector('.work-area');
  let scrollRaf = 0;
  // Only scroll to the top first when swapping would otherwise jump — i.e. when the
  // right column currently extends below the left column, so collapsing it would
  // yank the page height out from under the scroll. Otherwise swap in place.
  function transitionPanel(fillFn) {
    if (!current) {
      fillFn();
      return;
    }
    const swapInPlace = () => {
      panel.classList.add('exit');
      setTimeout(() => {
        fillFn();
        panel.classList.remove('exit');
      }, 200);
    };
    const wouldJump = workArea.getBoundingClientRect().bottom > sideEl.getBoundingClientRect().bottom + 1;
    if (!wouldJump || window.scrollY <= 1) {
      swapInPlace();
      return;
    }
    window.scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' });
    cancelAnimationFrame(scrollRaf);
    const start = performance.now();
    let faded = false;
    const FADE_AT = 300;
    const settle = () => {
      const sy = window.scrollY;
      if (!faded && sy <= FADE_AT) {
        panel.classList.add('exit');
        faded = true;
      }
      if (sy <= 2 || performance.now() - start > 1400) {
        fillFn();
        requestAnimationFrame(() => panel.classList.remove('exit'));
      } else {
        scrollRaf = requestAnimationFrame(settle);
      }
    };
    scrollRaf = requestAnimationFrame(settle);
  }
  function loadArticle(key, i) {
    const s = SECTIONS.find((x) => x.key === key);
    curArticle[key] = i;
    const wrap = cmds.querySelector(`.sublist[data-key="${key}"]`);
    if (wrap) [...wrap.querySelectorAll('.subitem')].forEach((b) => b.classList.toggle('on', +b.dataset.idx === i));
    panel.style.setProperty('--bh', s.hue);
    transitionPanel(() => {
      panel.innerHTML = `<div class="pbody">${renderArticleHTML(s, i)}</div>`;
    });
  }

  function dispatch(key) {
    if (key === current) return;
    const prev = current;
    const s = SECTIONS.find((x) => x.key === key);
    [...cmds.children].forEach((c) => {
      if (c.classList.contains('cmd')) c.classList.toggle('on', c.dataset.key === key);
    });
    cmds.querySelectorAll('.sublist').forEach((w) => w.classList.toggle('open', w.dataset.key === key));
    const fill = () => {
      panel.style.setProperty('--bh', s.hue);
      if (s.articles) {
        const i = curArticle[key] ?? 0;
        panel.innerHTML = `<div class="pbody">${renderArticleHTML(s, i)}</div>`;
        const wrap = cmds.querySelector(`.sublist[data-key="${key}"]`);
        if (wrap) [...wrap.querySelectorAll('.subitem')].forEach((b) => b.classList.toggle('on', +b.dataset.idx === i));
      } else {
        panel.innerHTML = `${s.noHead ? '' : `<div class="phead"><span class="pd"></span>${s.label}</div>`}<div class="pbody">${s.panel}</div>`;
      }
    };
    current = key;
    if (!prev) {
      fill();
      return;
    }
    transitionPanel(fill);
  }

  /* Chris talking */
  let talkTimer = 0,
    clearTimer = 0;
  function say(html, hold) {
    clearTimeout(clearTimer);
    bubble.innerHTML = html;
    bubble.classList.add('show');
    if (!reduce) {
      chris.classList.add('talk');
      clearTimeout(talkTimer);
      talkTimer = setTimeout(() => chris.classList.remove('talk'), 1500);
    }
    if (hold) clearTimer = setTimeout(() => bubble.classList.remove('show'), hold);
  }

  /* blink loop */
  if (!reduce) {
    (function blink() {
      const wait = 2600 + Math.random() * 3200;
      setTimeout(() => {
        chris.classList.add('blink');
        setTimeout(() => chris.classList.remove('blink'), 120);
        blink();
      }, wait);
    })();
  }

  /* ── the queue: agents line up, ask, get answered, then leave ── */
  const SLOTS = 4,
    STEP = 92;
  let hueI = 0,
    lastQ = -1,
    queue = [];
  function makeAgent() {
    const el = document.createElement('div');
    el.className = 'agent enter';
    el.style.setProperty('--ah', HUES[hueI++ % HUES.length]);
    el.innerHTML = `<div class="qbub"></div><div class="think"><i></i><i></i><i></i></div><div class="arig"><span class="ant"></span><div class="abody"><span class="aeye"></span><span class="aeye"></span></div><span class="glow"></span></div>`;
    queueEl.appendChild(el);
    return el;
  }
  function place(el, slot) {
    el.style.left = slot * STEP + 'px';
  }
  for (let i = 0; i < SLOTS; i++) {
    const a = makeAgent();
    queue.push(a);
    place(a, i);
  }
  setTimeout(() => queue.forEach((a) => a.classList.remove('enter')), 40);
  function nextQ() {
    let n;
    do {
      n = Math.floor(Math.random() * QA.length);
    } while (n === lastQ);
    lastQ = n;
    return QA[n];
  }

  function cycle() {
    const front = queue[0];
    if (!front) return;
    const qa = nextQ();
    front.classList.add('active', 'asking');
    front.querySelector('.qbub').textContent = qa.q;
    setTimeout(() => say('<b>' + qa.a + '</b>', 3200), 1300); // Chris answers
    setTimeout(() => {
      // front leaves, line advances
      front.classList.remove('asking');
      front.classList.add('leave');
      setTimeout(() => front.remove(), 520);
      queue.shift();
      queue.forEach((a, i) => place(a, i));
      const na = makeAgent();
      queue.push(na);
      place(na, queue.length - 1);
      setTimeout(() => na.classList.remove('enter'), 40);
    }, 3600);
    setTimeout(cycle, 5900);
  }

  /* intro, then start */
  dispatch('work');
  setTimeout(() => say("Hi — I'm <b>Chris</b>. There's usually a small line of agents with a question or two.", 4200), 400);
  setTimeout(cycle, 1600);
</script>
