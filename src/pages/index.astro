---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Chris Parcel"
  description="Chris Parcel — staff engineer in Los Angeles. About, experience, side projects, and writing."
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Onest:wght@400;500;600&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <header class="hero">
    <div class="id">
      <span class="nm">Chris Parcel</span>
    </div>
    <div class="contact">
      <a href="mailto:hello@chrisparcel.com">Email ↗</a>
      <a href="https://github.com/chrispy22" target="_blank" rel="noopener">GitHub ↗</a>
      <a href="https://www.linkedin.com/in/chris-parcel-167bb57/" target="_blank" rel="noopener">LinkedIn ↗</a>
    </div>
  </header>

  <div class="stage">
    <div class="content">
      <div class="side">
        <div class="cmds" id="cmds"></div>
      </div>
      <div class="sections" id="sections"></div>
    </div>
  </div>
</Layout>

<style is:global>
  .stage {
    max-width: 1180px;
    width: 100%;
    margin: 0 auto;
    padding: 0 40px 20px;
    flex: 1 0 auto;
  }

  /* ── HEADER ── */
  .hero {
    max-width: 1180px;
    width: 100%;
    margin: 0 auto;
    padding: 56px 40px 30px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
    flex-wrap: wrap;
  }
  .hero .contact {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    align-items: baseline;
    gap: 18px;
  }
  .hero .contact a {
    font-family: var(--sans);
    font-size: 13.5px;
    letter-spacing: 0.005em;
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-color: var(--rule);
    text-underline-offset: 3px;
    transition: color 0.2s, text-decoration-color 0.2s;
  }
  .hero .contact a:hover {
    color: var(--slate);
    text-decoration-color: var(--slate);
  }
  .hero .id {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .hero .nm {
    font-family: var(--display);
    font-weight: 600;
    font-size: 34px;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  /* dates use the site typeface (tabular figures), not a clashing mono */
  .jrow .y,
  .subitem .sy,
  .asub {
    font-family: var(--sans) !important;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
    font-weight: 500;
  }

  /* ── CONTENT (decoupled) ── */
  .content {
    margin-top: 0;
    padding-top: 44px;
    border-top: 1px solid var(--rule);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: 26px 40px;
    align-items: start;
  }
  .side {
    position: sticky;
    top: 20px;
    align-self: start;
  }
  .cmds {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .cmd {
    font-size: 16.5px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--ink-soft);
    cursor: pointer;
    text-align: left;
    background: none;
    border: 0;
    border-radius: 8px;
    padding: 9px 10px;
    margin-left: -10px;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: color 0.2s, background 0.2s;
  }
  .cmd:hover {
    color: var(--ink);
    background: color-mix(in oklch, var(--bh) 10%, transparent);
  }
  .cmd .dot {
    display: none;
  }
  .cmd .ar {
    margin-left: auto;
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: 18px;
    line-height: 1;
    display: flex;
    align-items: center;
    opacity: 0;
    transition: transform 0.2s, opacity 0.2s;
  }
  .cmd .ar svg {
    display: block;
  }
  .cmd:hover .ar {
    opacity: 1;
    transform: translateX(3px);
  }
  .cmd.on {
    color: var(--ink);
    background: none;
    font-weight: 550;
  }
  .cmd.on .dot {
    opacity: 1;
  }
  .cmd.on .ar {
    opacity: 1;
    color: var(--bh);
  }
  .cmd.on .ar {
    transform: translateX(3px);
  }

  .sublist {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    transition: grid-template-rows 0.34s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .sublist.open {
    grid-template-rows: 1fr;
  }
  .sublist > div {
    min-height: 0;
  }
  .sub {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: 3px 0 8px 0;
  }
  .subitem {
    font-size: 13.5px;
    font-weight: 500;
    color: var(--ink-faint);
    text-align: left;
    cursor: pointer;
    background: none;
    border: 0;
    border-radius: 8px;
    padding: 8px 10px;
    margin-left: 9px;
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: center;
    transition: color 0.2s, background 0.2s;
  }
  .subitem:hover {
    color: var(--ink);
    background: color-mix(in oklch, var(--bh) 10%, transparent);
  }
  .subitem.on {
    color: var(--ink);
    font-weight: 650;
    background: none;
  }
  .subitem .st {
    line-height: 1.3;
  }
  .subitem .sy {
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--ink-faint);
    flex: none;
  }

  .article h2 {
    margin-bottom: 5px;
  }
  .asub {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.03em;
    color: var(--ink-faint);
    margin: 0 0 18px;
  }
  .article p {
    font-size: 15.5px;
    color: var(--ink-soft);
    line-height: 1.62;
    margin: 0 0 13px;
  }
  .article p:last-child {
    margin-bottom: 0;
  }
  .article em {
    font-style: italic;
    color: var(--ink);
  }
  .article h3 {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--coral);
    margin: 28px 0 12px;
  }

  .pbody h2,
  .secbody h2 {
    font-family: var(--sans);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0 0 8px;
  }
  .secbody .lede {
    font-size: 16.5px;
    color: var(--ink-soft);
    line-height: 1.6;
    margin: 0 0 14px;
  }
  .secbody .lede:last-child {
    margin-bottom: 0;
  }
  .secbody b,
  .secbody strong {
    color: var(--ink);
    font-weight: 600;
  }
  .secbody em {
    font-style: italic;
    color: var(--ink);
  }
  /* feature bullet list (Central) */
  .flist {
    list-style: none;
    margin: 4px 0 16px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .flist li {
    position: relative;
    padding-left: 20px;
    font-size: 16.5px;
    line-height: 1.5;
    color: var(--ink-soft);
  }
  .flist li::before {
    content: '';
    position: absolute;
    left: 3px;
    top: 0.62em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--bh);
  }
  .jrow {
    display: grid;
    grid-template-columns: 1fr 62px;
    gap: 3px 18px;
    align-items: baseline;
    padding: 16px 0;
    border-top: 1px solid var(--rule);
  }
  .jrow:first-of-type {
    border-top: none;
    padding-top: 0;
  }
  .jrow .h {
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .jrow .h .r {
    color: var(--ink-soft);
    font-weight: 500;
  }
  .jrow .roles {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 62px;
    gap: 3px 18px;
    align-items: baseline;
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--ink-faint);
    margin-top: 1px;
  }
  .jrow .roles .y {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0;
    color: var(--ink-faint);
    white-space: nowrap;
  }
  .jrow .y {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0;
    color: var(--ink-faint);
    white-space: nowrap;
    justify-self: end;
  }
  .jrow .d {
    grid-column: 1;
    font-size: 15px;
    color: var(--ink-soft);
    line-height: 1.5;
    margin-top: 2px;
  }

  /* ── stacked scroll sections ── */
  .sec {
    padding: 48px 0;
    border-top: 1px solid var(--rule);
  }
  .sec:first-child {
    padding-top: 0;
    border-top: none;
  }
  .wstack {
    display: flex;
    flex-direction: column;
  }
  .wart {
    padding: 40px 0;
    border-top: 1px solid var(--rule);
  }
  .wart:first-child {
    padding-top: 0;
    border-top: none;
  }
  .colophon {
    padding: 22px 0 8px;
    font-family: var(--sans);
    font-size: 12.5px;
    letter-spacing: 0.01em;
    color: var(--ink-faint);
    line-height: 1.6;
  }
  .colophon a {
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-color: var(--rule);
    text-underline-offset: 3px;
  }
  .colophon a:hover {
    color: var(--slate);
    text-decoration-color: var(--slate);
  }

  /* device-framed app preview (static screenshot) */
  .demos {
    display: flex;
    margin: 26px 0 4px;
  }
  .demo.ios {
    flex: 0 0 auto;
  }
  .demo-img {
    display: block;
    width: 500px;
    max-width: 100%;
    height: auto;
  }

  @media (max-width: 900px) {
    .content {
      grid-template-columns: 1fr;
      gap: 22px;
    }
    .side {
      position: static;
    }
    .hero,
    .stage {
      padding-left: 24px;
      padding-right: 24px;
    }
  }
</style>

<script>
  /* Content sections — rendered stacked; the left nav is a scroll-spy */
  const SECTIONS = [
    {
      key: 'about',
      hue: '#3E5575',
      label: 'About',
      noHead: true,
      panel: `<p class="lede">Hello, I'm Chris, an iOS Developer based in Los Angeles, who's been building apps since 2009. I built my first app in college, shortly after iOS opened its App Store, and have been going non-stop since then.</p>
        <p class="lede">In my early 20s, I both founded and worked at a number of small startups in New York City before finally landing at Block (Square) in 2018. I spent 8 glorious years at Square, working on both product and platform. I learned a ton, shipped a lot, and loved working with so many amazing people who cared deeply about their craft and Square's users. Then, rather suddenly, I was part of the more than 4,000 employees let go during the company-wide layoff in February 2026.</p>
        <p class="lede">Since then, I've been working on a personal project which, I'm happy to announce, will be launching soon, and has given me a chance to really explore the depths of integrating AI into both product and development stack.</p>
        <p class="lede">I'm now open for new opportunities. Shoot me an email if you'd like to connect.</p>`,
    },
    {
      key: 'work',
      hue: '#2F9E94',
      label: 'Experience',
      noHead: true,
      panel: `<div class="jrow"><div class="h">Staff Software Engineer <span class="r">· Block (Square)</span></div><div class="y">2021–2026</div>
          <div class="roles"><span>Senior Engineer</span><span class="y">2018–2021</span></div>
          <div class="d">iOS Tech Lead for the Cart Platform team.</div></div>
        <div class="jrow"><div class="h">Senior iOS Developer <span class="r">· Verst</span></div><div class="y">2016–2017</div>
          <div class="d">One of two iOS developers who built a new mobile blogging tool.</div></div>
        <div class="jrow"><div class="h">iOS Consultant <span class="r">· Freelance</span></div><div class="y">2015–2016</div>
          <div class="d">Freelanced and pursued side projects while traveling around the world.</div></div>
        <div class="jrow"><div class="h">Lead iOS Developer <span class="r">· Keep.com</span></div><div class="y">2013–2015</div>
          <div class="d">Led a three-person team of mobile developers building a universal shopping cart app.</div></div>
        <div class="jrow"><div class="h">Co-Founder <span class="r">· Collectively Assembled</span></div><div class="y">2012–2013</div>
          <div class="d">Co-founded a fashion startup, raised $500k, shipped two apps in a year — one featured in the App Store.</div></div>
        <div class="jrow"><div class="h">B.A. Economics <span class="r">· UCLA</span></div><div class="y">2011</div>
          <div class="roles"><span>Minor in Human Complex Systems</span></div>
          <div class="d">McKelvey entrepreneurship scholar. Built a flashcard app featured in the App Store, sold it after graduation.</div></div>`,
    },
    {
      key: 'central',
      hue: '#D49A28',
      label: 'Side projects',
      noHead: true,
      panel: `<h2 style="margin-bottom:6px">Central</h2>
        <div class="asub">Coming soon</div>
        <p class="lede">Over the years I've shipped a handful of side projects: a photo-sharing app, a habit tracker, a travel-recs app. They were fun to build, but I realized that <em>having more apps on my phone wasn't making my life better</em>, so I started building one that would help consolidate and connect my varied interests in one simple experience.</p>
        <p class="lede"><b>Central</b> is a single, calm home for everything you want to remember: notes, to-dos, movie lists, recipes, birthdays, and much more.</p>
        <ul class="flist">
          <li><b>Offline-first.</b> Your data is always there, instantly.</li>
          <li><b>Real-time sync.</b> Everything stays current across all your devices.</li>
          <li><b>Zero-knowledge accounts.</b> Only you can read what you store.</li>
          <li><b>Easy sharing.</b> Collaborate on lists and pass recs to friends.</li>
          <li><b>Deep AI integration.</b> Capture and organization become effortless.</li>
          <li><b>AI chat.</b> Ask, build, and reference everything you've saved.</li>
        </ul>
        <p class="lede">I can't wait to launch it, and I hope you love using it.</p>
        <div class="demos">
          <div class="demo ios"><img class="demo-img" src="/sponge-ios-poster.png" alt="Sponge — the Central iOS app" loading="lazy" width="1120" height="2220" /></div>
        </div>`,
    },
    {
      key: 'writing',
      hue: '#E0523B',
      label: 'My writing',
      noHead: true,
      articles: [
        {
          title: 'Building Central',
          year: 'Draft',
          body: `<p>A short overview of Central: the itch that started it, the principles behind it (offline-first, private by default, and AI only where it earns its place), and where it's headed. Keep this one brief, the elevator version of the Side projects entry.</p>`,
        },
        {
          title: 'Prompt engineering',
          year: 'Draft',
          body: `<p>Notes on prompt engineering in practice: treating prompts like an admin surface, leaning on automated discovery instead of hand-holding, and the patterns that have actually held up. To flesh out with concrete before-and-after examples.</p>`,
        },
        {
          title: "Central's CRDT sync system",
          year: 'July 17, 2026',
          body: `<p>I built Central's sync from scratch. It has to work offline, stay end-to-end encrypted, and let every device edit freely and still converge to the same state. The server only ever holds encrypted operations, so the clients do the merging. The useful thing I learned building it was not a clever data structure. It was how little cleverness the problem actually needed.</p>
            <h3>The merge</h3>
            <p>Under the hood it is about as simple as sync gets: field-level last-writer-wins. Every change is a tiny operation with a timestamp. Edit the same field on two devices and the later timestamp wins; edit different fields and both survive. For structured data (to-dos, lists, dates, and tags), that is almost always the behavior you want. You do not merge two due dates. You take the newer one. Richer CRDTs, like Automerge, earn their complexity when two people edit inside the same value at once, typing into the same sentence of a shared document, where picking one writer would throw away the other's words. Central's data almost never works that way, so all that machinery would mostly sit idle.</p>
            <h3>Two clocks</h3>
            <p>The part that took me longest to see is that a sync system has two jobs that feel like one, and each needs its own clock. One job is settling conflicts: when two devices change the same field, which wins? Every operation carries a hybrid logical clock for that: mostly the device's wall clock, so the later edit usually wins, but with a counter to break exact ties and a rule that the clock only ever moves forward, never back. Any two edits then fall into one definite order that every device agrees on, even when their clocks are off. The other job is making sure a device has seen everything: the server stamps each operation as it arrives with a plain counter (one, two, three), so a device that has processed up to 4,812 just asks for everything after. Try to use one clock for both and it quietly breaks: fetch new work by wall-clock time and an edit made offline last week arrives looking older than what you have and never gets picked up. Two jobs, two clocks.</p>
            <h3>Out-of-order edits</h3>
            <p>There is one more wrinkle: an edit can arrive before the to-do it changes, since operations are numbered by when they reach the server rather than by what depends on what, and a batched import can deliver the two in either order. When that happens, the edit does not wait. It creates the to-do itself, right then, as a bare record carrying the one field it sets and nothing else. This is the very to-do the create will describe, sharing its id, just incomplete for the moment. When the create finally lands, it does not overwrite anything; it fills in the still-empty fields and leaves the edited one alone, since that field already holds the newer write. The record is correct the whole time. It only goes from partial to complete, and which of the two arrived first never mattered.</p>
            <h3>History and snapshots</h3>
            <p>On the server, I keep every operation a device has ever made, and that buys two things. Replay the log up to any point and you have the exact state from last Tuesday, or the moment before a bad import: full history, for free. And because the whole log lives there, no single device has to carry it. Once a device has folded everything up to a point into a snapshot, it can drop the operations behind that point and stay light, without ever losing the past, since the history is always available to pull back down.</p>
            <h3>Old and new clients</h3>
            <p>Devices update on their own schedules, so a brand-new client and a months-old one are often writing to the same workspace at once. Every operation is a typed protobuf message, which is what makes that safe: when an older client meets a field it does not recognize, it neither chokes nor silently drops it. It keeps the unknown bytes as they are, applies whatever it does understand, and forwards the rest untouched, so a newer client downstream still reads it in full. There is no coordinated migration and no taking the fleet offline to change the schema. Old and new clients simply coexist, and anything one of them cannot yet interpret rides along intact until it reaches one that can.</p>
            <h3>In conclusion</h3>
            <p>That is the whole system. While I can't say I'm itching to work on more multi-client sync machinery in the future, Central had a genuine need to work offline, stay encrypted, and agree across three platforms. Fitting a simple system to those constraints was satisfying, and I'm happy with how it turned out.</p>`,
        },
        {
          title: 'A zero-knowledge account system',
          year: 'Draft',
          body: `<p>How Central keeps data private: a zero-knowledge model where only the user can decrypt what they store. To cover key handling, account recovery, and exactly what the server can and cannot see.</p>`,
        },
        {
          title: 'AI skills and my development stack',
          year: 'Draft',
          body: `<p>A tour of the AI-assisted development stack I use day to day: the orchestrator, handoff protocols, code-health scanners, Linear, and how the pieces fit together. Aiming for a few minutes' read, not a manual.</p>`,
        },
        {
          title: 'Greenfield and trailing hardening',
          year: 'Draft',
          body: `<p>On building new projects fast: you don't stand up a design system first, and you don't harden every PR as you go. Coordinating magic values, extracting strings, and the consistency passes come later, as a deliberate trailing sweep once the shape has settled. To make the case for what belongs up front and what is better left to trail.</p>`,
        },
        {
          title: 'Using agents in production',
          year: 'Draft',
          body: `<p>Where AI agents actually earn their keep in production, and how to run them safely: guardrails, review gates, and the failure modes worth planning for. The through-line is that useful and safe are not at odds if you design for both.</p>`,
        },
        {
          title: 'Generative UI',
          year: 'July 17, 2026',
          body: `<p>Generative UI is the idea that an interface can be assembled on the fly, by a model, around whatever you are trying to do right now, instead of being designed once and shipped to everyone. Projects like Monogram and Open UI are circling the space from different angles: the former is building an end-user application, and the latter provides open-source tooling.</p>
            <p>The pitch is genuinely exciting: no more one-size-fits-all screens, smaller navigation topologies, and possibly per-user customization. The interface becomes a response to your intent rather than a fixed map you have to learn, and you are no longer beholden to the limitations of chat-centric UI.</p>
            <p>The catch is that most of what makes a tool feel fast and legible is familiarity. We do not really read the interfaces we use all day; we reach for them. The button is always in that corner, the shortcut lives in your fingers, and the layout is a place you know. A UI that rearranges itself to be perfect for this exact moment is, by definition, one you can never build muscle memory for. Optimal-every-time and learnable-once are in tension, and for anything you do often, learnable-once tends to win.</p>
            <p>Of course, there's no specific reason why generative UI would need to change more often than it should, but the question then becomes: how often does it change? Does this fit on the developer's timetable (they can already use Claude Design or similar), or the user's?</p>
            <p>At the moment, I do not quite see how apps, as we know them, will make real use of generative UI. But I do see a role for it in something bigger: the era of personal computing that comes after iOS and Android. What I believe, and hope for, is that personal computing itself will fade into the background. The image of someone always on their laptop already feels old, and in a decade the same may well be true for phones. So not the next page generated instead of pre-built, but an entirely new paradigm for how we relate to our machines, where the interface is less a place you go and more something that arranges itself quietly around your life.</p>`,
        },
        {
          title: 'Collaboration in the age of AI',
          year: 'July 17, 2026',
          body: `<p>For most of my career, a team was a group of people who divided the work and, in doing so, stayed woven together. You cut the work into tickets, paired or picked swim lanes, and reviewed each other's pull requests. The dividing was how the doing got done, but it was also how knowledge spread, how people grew, and how a group of individuals became a team. The connection was a byproduct of the process.</p>
            <p>AI is pulling that apart. One person and a good model can now carry a whole feature from idea to merge, so the natural move is to optimize for individual output. And it works, at least on the surface. But when everyone is a self-contained unit, the connective tissue goes too. The shared context thins, the mutual understanding fades, and the team quietly becomes a set of high-throughput individuals who happen to share a repo. We are, for a moment, more productive and less of a team.</p>
            <p>I think we get the team back, but not by returning to the old habit of dividing the work. We get it back one level up by building the system that does the work together. The unit of collaboration becomes the machine that produces features: the prompts and skills, the agents and orchestration, the guardrails and tests, the code-health checks, the shared context the models draw on. Owning and improving that system together is the new version of what dividing the work used to give us for free. You stay connected by building and debugging the machine instead of the feature. Knowledge spreads because the system is shared and legible. People grow by improving the thing that improves everything else.</p>
            <p>None of this will arrive evenly. The shift will be lumpy, and for a while it will be a mess. I'm confident, however, that a new normal will arrive, and humans will collaborate with each other once again.</p>`,
        },
        {
          title: 'Roles in the modern workplace',
          year: 'Draft',
          body: `<p>What titles and roles mean now that AI does a real chunk of the work. A few hot takes to react to (I'll pick a lane):</p>
            <ul class="flist">
              <li>The lines between engineer, designer, and PM are dissolving; the valuable person is the one who can hold the whole problem.</li>
              <li>Generalists beat specialists again, because AI collapses the cost of switching context.</li>
              <li>The most future-proof skill isn't coding or design, it's clearly specifying what "good" looks like.</li>
              <li>Management becomes more about taste and judgment than coordination, since the coordination is increasingly automated.</li>
              <li>Headcount stops being the proxy for ambition; small teams ship what used to need departments.</li>
              <li>The junior on-ramp changes rather than disappears: you're expected to direct AI on day one, not just write code.</li>
            </ul>`,
        },
        {
          title: 'My time at Block',
          year: 'July 16, 2026',
          body: `<p>I spent a little over eight years at Block before my role was affected by the company-wide layoffs in February 2026. In that time, I worked across both product and platform, shipped countless releases, and learned what it takes to deliver not just an app, but software that millions of people rely on for their livelihood. Bugs were real, wins felt great.</p><p>Before my time there, I was mostly an iOS developer. I could make apps. When I left, I had an entirely different perspective on software and the people it serves. The app was an important tool; the platform, along with the problems it solved and the pain points it relieved, was what mattered most. The most valuable skill I picked up along the way was learning to figure out what things actually counted, and how a culture that cares about these things gets built.</p><p>And of course, the hundred or so people I got to know and work with closely made all the difference. Learning from, and later leading, some of the most talented and caring people I've ever met is an experience I'll never forget.</p><p>Wishing all Squares, present and past, a bright future, and hoping to get to work with you all again.</p>`,
        },
      ],
    },
  ];

  const reduce = matchMedia('(prefers-reduced-motion:reduce)').matches;
  const cmds = document.getElementById('cmds');
  const sections = document.getElementById('sections');

  function renderArticleHTML(s, i) {
    const a = s.articles[i];
    return `<div class="article"><h2>${a.title}</h2><div class="asub">${a.year}</div>${a.body}</div>`;
  }
  function goToArticle(key, i) {
    const el = document.getElementById('art-' + key + '-' + i);
    if (!el) return;
    const y = el.getBoundingClientRect().top + window.scrollY - 24;
    window.scrollTo({ top: Math.max(0, y), behavior: reduce ? 'auto' : 'smooth' });
  }

  /* left nav (+ writing sub-list) + stacked right-column sections */
  SECTIONS.forEach((s) => {
    const c = document.createElement('button');
    c.className = 'cmd';
    c.dataset.key = s.key;
    c.style.setProperty('--bh', s.hue);
    const arw = s.articles
      ? '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>'
      : '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>';
    c.innerHTML = `<span class="dot"></span>${s.label}<span class="ar">${arw}</span>`;
    c.addEventListener('click', () => goTo(s.key));
    cmds.appendChild(c);

    if (s.articles) {
      const wrap = document.createElement('div');
      wrap.className = 'sublist';
      wrap.dataset.key = s.key;
      wrap.style.setProperty('--bh', s.hue);
      const inner = document.createElement('div');
      const sub = document.createElement('div');
      sub.className = 'sub';
      s.articles.forEach((a, i) => {
        const b = document.createElement('button');
        b.className = 'subitem';
        b.dataset.idx = i;
        b.innerHTML = `<span class="st">${a.title}</span><span class="sy">${a.year}</span>`;
        b.addEventListener('click', () => goToArticle(s.key, i));
        sub.appendChild(b);
      });
      inner.appendChild(sub);
      wrap.appendChild(inner);
      cmds.appendChild(wrap);
    }

    const sec = document.createElement('section');
    sec.className = 'sec';
    sec.id = 'sec-' + s.key;
    sec.dataset.key = s.key;
    sec.style.setProperty('--bh', s.hue);
    if (s.articles) {
      sec.innerHTML =
        `<div class="secbody"><div class="wstack">` +
        s.articles
          .map((a, i) => `<div class="wart" id="art-${s.key}-${i}">${renderArticleHTML(s, i)}</div>`)
          .join('') +
        `</div></div>`;
    } else {
      sec.innerHTML = `<div class="secbody">${s.panel}</div>`;
    }
    sections.appendChild(sec);
  });

  /* tail spacer: guarantee the page can scroll far enough that even a short
     last section's top reaches the scroll-spy activation line */
  const tail = document.createElement('div');
  tail.className = 'tailspace';
  sections.appendChild(tail);
  const colo = document.createElement('div');
  colo.className = 'colophon';
  colo.innerHTML = `Designed &amp; coded with Claude. Inspiration from Brittany Chiang's <a href="https://brittanychiang.com/" target="_blank" rel="noopener">site</a>.`;
  sections.appendChild(colo);
  function updateSpacer() {
    tail.style.height = '0px';
    const arts = sections.querySelectorAll('.wart');
    const secs = sections.querySelectorAll('.sec');
    const last = arts.length ? arts[arts.length - 1] : secs[secs.length - 1];
    if (!last) return;
    const coloH = colo.getBoundingClientRect().height;
    const need = window.innerHeight - 240 - last.getBoundingClientRect().height + 24 - coloH;
    tail.style.height = Math.max(0, need) + 'px';
  }
  updateSpacer();

  /* click a nav item -> smooth-scroll to its section */
  function goTo(key) {
    const el = document.getElementById('sec-' + key);
    if (!el) return;
    const y = el.getBoundingClientRect().top + window.scrollY - 24;
    window.scrollTo({ top: Math.max(0, y), behavior: reduce ? 'auto' : 'smooth' });
  }

  /* scroll-spy: highlight the section currently in view */
  const cmdEls = [...cmds.querySelectorAll('.cmd')];
  const secEls = SECTIONS.map((s) => document.getElementById('sec-' + s.key));
  let spyRaf = 0;
  function spy() {
    spyRaf = 0;
    let active = SECTIONS[0].key;
    for (const el of secEls) {
      if (el.getBoundingClientRect().top <= 240) active = el.dataset.key;
      else break;
    }
    if (
      window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 4 &&
      secEls[secEls.length - 1].getBoundingClientRect().top <= 240
    )
      active = SECTIONS[SECTIONS.length - 1].key;
    cmdEls.forEach((c) => c.classList.toggle('on', c.dataset.key === active));
    cmds.querySelectorAll('.sublist').forEach((w) => w.classList.toggle('open', w.dataset.key === active));
    const atBottom = window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 4;
    SECTIONS.forEach((s) => {
      if (!s.articles) return;
      const wrap = cmds.querySelector(`.sublist[data-key="${s.key}"]`);
      if (!wrap) return;
      const arts = [...document.querySelectorAll(`#sec-${s.key} .wart`)];
      let ai = 0;
      arts.forEach((el, idx) => {
        if (el.getBoundingClientRect().top <= 240) ai = idx;
      });
      if (atBottom) ai = arts.length - 1;
      [...wrap.querySelectorAll('.subitem')].forEach((b) => b.classList.toggle('on', +b.dataset.idx === ai));
    });
  }
  addEventListener('scroll', () => {
    if (!spyRaf) spyRaf = requestAnimationFrame(spy);
  }, { passive: true });
  addEventListener('resize', () => {
    updateSpacer();
    if (!spyRaf) spyRaf = requestAnimationFrame(spy);
  });
  spy();
</script>
